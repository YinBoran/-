// HELPERS
// ═══════════════════════════════════════════════════════════
function cm(h){ const m={}; h.forEach((k,i)=>m[String(k).trim()]=i); return m; }
function s(r,hm,col){ const i=hm[col]; return i!==undefined?String(r[i]||'').trim():''; }
function e(v){ return String(v||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function t(v,n){ v=String(v||''); return v.length>n?v.slice(0,n)+'…':v; }
function pd(v){ if(!v) return null; if(v instanceof Date) return v; const m=String(v).match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})/); if(m) return new Date(+m[3],+m[2]-1,+m[1]); return new Date(v); }

function sBdg(v){ const t=String(v||'').toLowerCase(); if(t.includes('complet')) return `<span class="bdg b-g">${v}</span>`; if(t.includes('approv')) return `<span class="bdg b-b">${v}</span>`; if(t.includes('cancel')) return `<span class="bdg b-r">${v}</span>`; return `<span class="bdg b-a">${v||'Pending'}</span>`; }
function pBdg(v){ const t=String(v||'').toLowerCase(); if(t.includes('paid')&&!t.includes('⚠')) return `<span class="bdg b-g">Paid</span>`; if(t.includes('⚠')) return `<span class="bdg b-a">Partial</span>`; if(t.includes('cod')) return `<span class="bdg b-i">${v}</span>`; return `<span class="bdg b-x">${t(v,14)||'—'}</span>`; }
function sstBdg(v){ const t=String(v||'').toLowerCase(); if(t.includes('out')) return `<span class="bdg b-r">Out of Stock</span>`; if(t.includes('low')) return `<span class="bdg b-a">Low Stock</span>`; if(t.includes('in')) return `<span class="bdg b-g">In Stock</span>`; return `<span class="bdg b-x">${v||'—'}</span>`; }


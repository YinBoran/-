<!DOCTYPE html>
<html lang="km">
<head>
<base target="_top">
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title id="doc-title">YB Manages</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=Kantumruy+Pro:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ═══ VARIABLES ═══════════════════════════════════════════ */
:root{
  --p:#1A73E8; --p-lt:#D3E3FD; --p-dk:#041E49;
  --bg:#F6F8FC; --card:#fff; --text:#202124; --muted:#5F6368; --border:#DADCE0;
  --green:#1E8E3E; --green-lt:#E6F4EA;
  --amber:#F29900; --amber-lt:#FEF7E0;
  --red:#D93025;   --red-lt:#FCE8E6;
  --indigo:#5C6BC0;--indigo-lt:#E8EAF6;
  --teal:#00796B;  --teal-lt:#E0F2F1;
  --sb:256px; --tb:64px; --r:8px;
  --sh:0 1px 3px rgba(60,64,67,.3),0 1px 3px rgba(60,64,67,.15);
  --sh-sm:0 1px 2px rgba(60,64,67,.2);
  --font:'DM Sans','Kantumruy Pro',sans-serif;
  --ease:cubic-bezier(.4,0,.2,1);
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden} /* FIX: prevent page-level scroll */
body{font-family:var(--font);background:var(--bg);color:var(--text);-webkit-font-smoothing:antialiased}
button{font-family:inherit;cursor:pointer}
input,select,textarea{font-family:inherit}

/* ═══ AUTH ═══════════════════════════════════════════════ */
#auth{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;background:var(--bg);z-index:9000}
#auth.hidden{display:none}
.auth-box{width:360px;background:var(--card);border-radius:12px;padding:48px 40px 40px;box-shadow:var(--sh);text-align:center}
.auth-av{width:56px;height:56px;border-radius:50%;background:var(--p);color:#fff;font-size:20px;font-weight:800;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;overflow:hidden}
.auth-av img{width:100%;height:100%;object-fit:cover}
.auth-title{font-size:22px;font-weight:700;margin-bottom:6px}
.auth-sub{font-size:13px;color:var(--muted);margin-bottom:24px}
.auth-inp{width:100%;padding:11px 14px;border:1px solid var(--border);border-radius:var(--r);font-size:14px;outline:none;transition:border .2s;margin-bottom:10px}
.auth-inp:focus{border-color:var(--p);box-shadow:0 0 0 2px #1A73E820}
.auth-btn{width:100%;padding:11px;background:var(--p);color:#fff;border:none;border-radius:var(--r);font-size:14px;font-weight:600;letter-spacing:.3px;transition:opacity .2s}
.auth-btn:hover{opacity:.87}
.auth-err{color:var(--red);font-size:12px;margin-top:8px;min-height:16px}

/* ═══ APP SHELL ══════════════════════════════════════════ */
#app{display:flex;height:100vh;overflow:hidden;opacity:0;transition:opacity .3s}
#app.ready{opacity:1}
#app.hidden{display:none}

/* ═══ SIDEBAR ════════════════════════════════════════════ */
#sb{width:var(--sb);min-width:var(--sb);height:100vh;background:var(--card);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;transition:width .2s var(--ease),min-width .2s var(--ease);z-index:200;flex-shrink:0}
#sb.col{width:72px;min-width:72px}
.sb-head{display:flex;align-items:center;height:var(--tb);padding:0 16px 0 20px;gap:12px;border-bottom:1px solid var(--border);flex-shrink:0}
#sb-logo{width:36px;height:36px;border-radius:var(--r);background:var(--p);color:#fff;font-size:13px;font-weight:800;display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0}
#sb-logo img{width:100%;height:100%;object-fit:contain}
.sb-brand{flex:1;overflow:hidden;min-width:0;transition:opacity .2s}
#sb-name{font-size:14px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
#sb-sub{font-size:11px;color:var(--muted);margin-top:1px}
#sb.col .sb-brand{opacity:0;width:0;pointer-events:none}
.sb-tog{width:32px;height:32px;border:none;background:none;border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--muted);flex-shrink:0}
.sb-tog:hover{background:var(--bg)}
.sb-tog svg{width:20px;height:20px;fill:currentColor}
.sb-nav{flex:1;overflow-y:auto;overflow-x:hidden;padding:8px}
.nb-item{display:flex;align-items:center;gap:14px;padding:10px 12px;border-radius:var(--r);cursor:pointer;color:var(--muted);font-size:14px;font-weight:500;white-space:nowrap;overflow:hidden;border:none;background:none;width:100%;transition:all .15s;position:relative}
.nb-item:hover{background:var(--bg);color:var(--text)}
.nb-item.on{background:var(--p-lt);color:var(--p);font-weight:600}
.nb-icon{width:22px;height:22px;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.nb-icon svg{width:20px;height:20px;fill:currentColor}
.nb-lbl{overflow:hidden;transition:opacity .15s,width .15s}
#sb.col .nb-lbl{opacity:0;width:0}
.nb-bdg{margin-left:auto;background:var(--p);color:#fff;font-size:10px;font-weight:700;padding:2px 6px;border-radius:99px;flex-shrink:0}
#sb.col .nb-bdg{display:none}
.sb-sep{font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;padding:12px 12px 4px;white-space:nowrap;overflow:hidden;transition:opacity .15s}
#sb.col .sb-sep{opacity:0}
.sb-foot{border-top:1px solid var(--border);padding:8px}
.sb-user{display:flex;align-items:center;gap:12px;padding:10px 12px;border-radius:var(--r);overflow:hidden}
.sb-av{width:32px;height:32px;border-radius:50%;background:var(--p);color:#fff;font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sb-un{font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;transition:opacity .15s}
#sb.col .sb-un{opacity:0;width:0}

/* ═══ MAIN ═══════════════════════════════════════════════ */
.main{flex:1;display:flex;flex-direction:column;height:100vh;overflow:hidden;min-width:0}
.topbar{height:var(--tb);background:var(--card);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 24px;gap:12px;flex-shrink:0;z-index:100}
.tb-crumb{font-size:16px;font-weight:700;white-space:nowrap}
.tb-srch{flex:1;max-width:480px;position:relative;margin:0 16px}
.tb-srch input{width:100%;padding:8px 14px 8px 36px;border:1px solid var(--border);border-radius:24px;font-size:13px;background:var(--bg);outline:none;transition:all .2s}
.tb-srch input:focus{background:var(--card);border-color:var(--p);box-shadow:0 0 0 2px #1A73E820}
.tb-srch svg{position:absolute;left:11px;top:50%;transform:translateY(-50%);width:15px;height:15px;fill:var(--muted)}
.tb-right{display:flex;align-items:center;gap:8px;margin-left:auto}
.chip{padding:3px 10px;border-radius:99px;font-size:11px;font-weight:700}
.chip.test{background:var(--amber-lt);color:var(--amber)}
.chip.prod{background:var(--green-lt);color:var(--green)}
.tb-btn{height:34px;padding:0 12px;border:1px solid var(--border);border-radius:var(--r);font-size:13px;font-weight:500;background:var(--card);color:var(--text);display:flex;align-items:center;gap:5px;transition:all .15s;white-space:nowrap}
.tb-btn:hover{border-color:var(--p);color:var(--p)}
.tb-btn.pri{background:var(--p);color:#fff;border-color:var(--p)}
.tb-btn.pri:hover{opacity:.87}
.tb-btn svg{width:15px;height:15px;fill:currentColor}

/* content area scrolls, not the whole page */
.content{flex:1;overflow-y:auto;padding:24px;scroll-behavior:smooth}
.page{display:none}.page.on{display:block}
.pg-head{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:24px;gap:12px;flex-wrap:wrap}
.pg-title{font-size:22px;font-weight:800;letter-spacing:-.4px}
.pg-sub{font-size:13px;color:var(--muted);margin-top:4px}

/* ═══ METRICS ═══════════════════════════════════════════ */
.metrics{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:14px;margin-bottom:24px}
.mc{background:var(--card);border-radius:var(--r);padding:18px 20px;border:1px solid var(--border);box-shadow:var(--sh-sm);position:relative;overflow:hidden;cursor:default}
.mc::before{content:'';position:absolute;left:0;top:0;bottom:0;width:4px}
.mc.blue::before{background:var(--p)} .mc.green::before{background:var(--green)}
.mc.amber::before{background:var(--amber)} .mc.red::before{background:var(--red)}
.mc.indigo::before{background:var(--indigo)}.mc.teal::before{background:var(--teal)}
.mc-ico{width:36px;height:36px;border-radius:var(--r);display:flex;align-items:center;justify-content:center;margin-bottom:10px}
.mc-ico svg{width:20px;height:20px}
.mc.blue .mc-ico{background:var(--p-lt)} .mc.blue .mc-ico svg{fill:var(--p)}
.mc.green .mc-ico{background:var(--green-lt)} .mc.green .mc-ico svg{fill:var(--green)}
.mc.amber .mc-ico{background:var(--amber-lt)} .mc.amber .mc-ico svg{fill:var(--amber)}
.mc.red .mc-ico{background:var(--red-lt)} .mc.red .mc-ico svg{fill:var(--red)}
.mc.indigo .mc-ico{background:var(--indigo-lt)} .mc.indigo .mc-ico svg{fill:var(--indigo)}
.mc.teal .mc-ico{background:var(--teal-lt)} .mc.teal .mc-ico svg{fill:var(--teal)}
.mc-val{font-size:26px;font-weight:800;letter-spacing:-.5px;line-height:1}
.mc-lbl{font-size:12px;color:var(--muted);margin-top:4px;font-weight:500}

/* ═══ CARDS / SECTIONS ══════════════════════════════════ */
.sec{background:var(--card);border-radius:var(--r);border:1px solid var(--border);box-shadow:var(--sh-sm);margin-bottom:20px;overflow:hidden}
.sec-h{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--border)}
.sec-t{font-size:15px;font-weight:700}
.sec-b{padding:16px 18px}
.dash-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}

/* ═══ TABLE ═════════════════════════════════════════════ */
.tbl-wrap{background:var(--card);border-radius:var(--r);border:1px solid var(--border);box-shadow:var(--sh-sm);overflow:hidden}
.tbl-bar{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid var(--border);gap:12px;flex-wrap:wrap;flex-shrink:0}
.tbl-count{font-size:12px;color:var(--muted);font-weight:500}
.tbl-body{overflow-y:auto;max-height:calc(100vh - 320px)} /* scrollable table body */
.tbl{width:100%;border-collapse:collapse;font-size:13px}
.tbl thead{background:#F8F9FA;position:sticky;top:0;z-index:10}
.tbl th{padding:10px 13px;text-align:left;font-weight:600;color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.5px;border-bottom:2px solid var(--border);white-space:nowrap;cursor:pointer;user-select:none}
.tbl th:hover{color:var(--text)}
.si{display:inline-block;margin-left:4px;opacity:.3}
.si::after{content:'↕'}
.sorted-a .si::after{content:'↑';opacity:1;color:var(--p)}
.sorted-d .si::after{content:'↓';opacity:1;color:var(--p)}
.tbl td{padding:10px 13px;border-bottom:1px solid #F1F3F4;vertical-align:middle}
.tbl td.num{font-weight:600;font-variant-numeric:tabular-nums}
.tbl tr:hover td{background:#F8FBFF}
.tbl tr:last-child td{border-bottom:none}
.ra{display:flex;gap:3px;align-items:center}
.rb{width:28px;height:28px;border:none;background:none;border-radius:50%;display:flex;align-items:center;justify-content:center;transition:background .15s}
.rb:hover{background:var(--bg)}
.rb.e:hover svg{fill:var(--p)}
.rb.d:hover{background:var(--red-lt)}
.rb.d:hover svg{fill:var(--red)}
.rb.p:hover svg{fill:var(--green)}
.rb svg{width:15px;height:15px;fill:var(--muted)}
.empty-row{text-align:center;padding:48px;color:var(--muted);font-size:14px}
/* infinite scroll sentinel */
#cust-sentinel,#prod-sentinel{height:40px;display:flex;align-items:center;justify-content:center}
.load-more-spin{display:none;width:20px;height:20px;border:2px solid var(--border);border-top-color:var(--p);border-radius:50%;animation:spin .6s linear infinite}
.loading-more .load-more-spin{display:inline-block}
@keyframes spin{to{transform:rotate(360deg)}}

/* ═══ FILTER BAR ════════════════════════════════════════ */
.fbar{display:flex;align-items:center;gap:8px;margin-bottom:14px;flex-wrap:wrap}
.fbar input,.fbar select{height:34px;padding:0 11px;border:1px solid var(--border);border-radius:var(--r);font-size:13px;background:var(--card);outline:none;color:var(--text);transition:border .2s}
.fbar input:focus,.fbar select:focus{border-color:var(--p)}
.fs-wrap{position:relative}
.fs-wrap svg{position:absolute;left:10px;top:50%;transform:translateY(-50%);width:13px;height:13px;fill:var(--muted)}
.fs-wrap input{padding-left:30px;min-width:200px}

/* ═══ BADGES ════════════════════════════════════════════ */
.bdg{display:inline-flex;align-items:center;padding:2px 8px;border-radius:99px;font-size:11px;font-weight:600;white-space:nowrap}
.b-g{background:var(--green-lt);color:var(--green)}
.b-a{background:var(--amber-lt);color:var(--amber)}
.b-r{background:var(--red-lt);color:var(--red)}
.b-b{background:var(--p-lt);color:var(--p)}
.b-i{background:var(--indigo-lt);color:var(--indigo)}
.b-t{background:var(--teal-lt);color:var(--teal)}
.b-x{background:#F1F3F4;color:var(--muted)}
.stk-bar{height:5px;border-radius:3px;background:var(--border);margin-top:3px;overflow:hidden}
.stk-fill{height:100%;border-radius:3px;transition:width .4s}

/* ═══ SKELETON LOADING ══════════════════════════════════ */
.skel{background:linear-gradient(90deg,#F1F3F4 25%,#E8EBEE 50%,#F1F3F4 75%);background-size:200%;animation:shimmer 1.4s infinite;border-radius:4px}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
.skel-row{display:flex;align-items:center;gap:12px;padding:11px 16px;border-bottom:1px solid #F5F6F7}
.skel-cell{height:12px;border-radius:4px}
.skel-m{width:36px;height:36px;border-radius:var(--r)}
.mc-skel{background:var(--card);border-radius:var(--r);padding:18px 20px;border:1px solid var(--border);box-shadow:var(--sh-sm)}

/* ═══ MODAL — FIXED so it never scrolls with page ══════ */
.ovl{position:fixed;inset:0;background:rgba(32,33,36,.5);z-index:500;opacity:0;transition:opacity .2s;pointer-events:none;backdrop-filter:blur(2px)}
.ovl.on{opacity:1;pointer-events:all}
.mdl{position:fixed;top:50%;left:50%;transform:translate(-50%,-48%) scale(.96);z-index:600;background:var(--card);border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,.2);width:min(580px,95vw);max-height:88vh;display:flex;flex-direction:column;opacity:0;pointer-events:none;transition:all .2s var(--ease)}
.mdl.on{opacity:1;pointer-events:all;transform:translate(-50%,-50%) scale(1)}
/* prevent background scroll while modal open */
body.modal-open{overflow:hidden}
.mdl-h{display:flex;align-items:center;justify-content:space-between;padding:18px 22px 14px;border-bottom:1px solid var(--border);flex-shrink:0}
.mdl-title{font-size:16px;font-weight:700}
.mdl-x{width:30px;height:30px;border:none;background:none;border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--muted)}
.mdl-x:hover{background:var(--bg);color:var(--text)}
.mdl-x svg{width:17px;height:17px;fill:currentColor}
.mdl-b{padding:18px 22px;overflow-y:auto;flex:1}
.mdl-f{display:flex;justify-content:flex-end;gap:10px;padding:14px 22px 18px;border-top:1px solid var(--border);flex-shrink:0}

/* ═══ FORMS ═════════════════════════════════════════════ */
.fg{display:grid;grid-template-columns:1fr 1fr;gap:12px 14px}
.fg .s2{grid-column:1/-1}
.fld{display:flex;flex-direction:column;gap:4px}
.fld label{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px}
.fld input,.fld select,.fld textarea{padding:9px 11px;border:1px solid var(--border);border-radius:var(--r);font-size:13px;outline:none;transition:border .2s;background:var(--card);color:var(--text)}
.fld input:focus,.fld select:focus,.fld textarea:focus{border-color:var(--p);box-shadow:0 0 0 2px #1A73E815}
.fld textarea{resize:vertical;min-height:72px}
.fld .ro{background:#F8F9FA;color:var(--muted);cursor:not-allowed}
.fld .hint{font-size:11px;color:var(--muted);margin-top:2px}
.fld .info-chip{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;background:var(--bg);border-radius:99px;font-size:12px;font-weight:500;margin-top:4px;border:1px solid var(--border)}
/* tag input for categories */
.tag-wrap{border:1px solid var(--border);border-radius:var(--r);padding:6px 8px;display:flex;flex-wrap:wrap;gap:4px;cursor:text;transition:border .2s;background:var(--card)}
.tag-wrap:focus-within{border-color:var(--p);box-shadow:0 0 0 2px #1A73E815}
.tag-chip{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;background:var(--p-lt);color:var(--p);border-radius:99px;font-size:12px;font-weight:600}
.tag-chip button{width:14px;height:14px;border:none;background:none;color:var(--p);display:flex;align-items:center;justify-content:center;padding:0;font-size:13px;line-height:1;border-radius:50%}
.tag-chip button:hover{background:var(--p);color:#fff}
.tag-wrap input{border:none;outline:none;font-size:13px;min-width:80px;background:transparent;font-family:inherit}
.auto-code{font-family:'Courier New',monospace;font-size:13px;font-weight:700;color:var(--p);background:var(--p-lt);padding:4px 8px;border-radius:4px;margin-top:2px}

/* ═══ BUTTONS ═══════════════════════════════════════════ */
.btn{height:34px;padding:0 16px;border-radius:var(--r);font-size:13px;font-weight:600;border:none;transition:all .15s;display:inline-flex;align-items:center;gap:5px;letter-spacing:.1px;white-space:nowrap}
.btn-p{background:var(--p);color:#fff}.btn-p:hover{opacity:.87}
.btn-o{background:none;border:1px solid var(--border);color:var(--text)}.btn-o:hover{border-color:var(--p);color:var(--p)}
.btn-r{background:none;border:1px solid var(--red);color:var(--red)}.btn-r:hover{background:var(--red-lt)}
.btn-g{background:var(--green);color:#fff}.btn-g:hover{opacity:.87}
.btn svg{width:14px;height:14px;fill:currentColor}

/* ═══ CHARTS ════════════════════════════════════════════ */
.ch-row{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.ch-lbl{font-size:12px;color:var(--muted);width:80px;flex-shrink:0;text-align:right;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ch-track{flex:1;height:22px;background:var(--bg);border-radius:4px;overflow:hidden}
.ch-fill{height:100%;border-radius:4px;transition:width .8s var(--ease);display:flex;align-items:center;justify-content:flex-end;padding-right:7px}
.ch-fill span{font-size:10px;font-weight:800;color:#fff}

/* ═══ SETTINGS ══════════════════════════════════════════ */
.srow{display:flex;align-items:center;justify-content:space-between;padding:11px 0;border-bottom:1px solid #F1F3F4;gap:14px}
.srow:last-child{border-bottom:none}
.sk{font-size:13px;font-weight:500;flex:1}
.sv{font-size:13px;color:var(--muted);max-width:260px;text-align:right;word-break:break-all}
.sv.ok::before{content:'● ';color:var(--green)}
.sv.no::before{content:'○ ';color:var(--red)}

/* ═══ ALERTS ════════════════════════════════════════════ */
.alert-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid #F5F6F7}
.alert-row:last-child{border-bottom:none}

/* ═══ TOAST ═════════════════════════════════════════════ */
#toasts{position:fixed;bottom:20px;right:20px;display:flex;flex-direction:column;gap:7px;z-index:9999;pointer-events:none}
.toast{background:var(--text);color:#fff;padding:11px 15px;border-radius:var(--r);font-size:13px;font-weight:500;box-shadow:var(--sh);display:flex;align-items:center;gap:9px;animation:tin .25s var(--ease);pointer-events:all;min-width:220px}
.toast.success{background:var(--green)}.toast.error{background:var(--red)}.toast.warning{background:var(--amber);color:var(--text)}
.toast.out{animation:tout .25s var(--ease) forwards}
.toast svg{width:15px;height:15px;fill:currentColor;flex-shrink:0}
@keyframes tin{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:none}}
@keyframes tout{to{opacity:0;transform:translateX(20px)}}

/* ═══ PRINT ══════════════════════════════════════════════ */
@media screen{#pz{display:none}}
@media print{
  body > *:not(#pz){display:none!important}
  #pz{display:block!important}
  /* Shipping label (small) */
  .lbl-sm{width:148mm;padding:10mm;font-family:var(--font)}
  .lbl-sm .lbl-h{font-size:18px;font-weight:900;border-bottom:2px solid #000;padding-bottom:6px;margin-bottom:10px}
  .lbl-sm .lbl-row{font-size:13px;margin:5px 0}
  /* A5 invoice */
  .inv-a5{width:148mm;padding:14mm;font-family:var(--font)}
  .inv-a5 .inv-h{display:flex;justify-content:space-between;align-items:flex-start;border-bottom:2px solid #000;padding-bottom:12px;margin-bottom:16px}
  .inv-a5 .inv-logo{font-size:20px;font-weight:900}
  .inv-a5 .inv-meta p{font-size:11px;text-align:right}
  .inv-a5 h4{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:#555;border-bottom:1px solid #ddd;padding-bottom:3px;margin-bottom:8px;margin-top:12px}
  .inv-a5 p{font-size:12px;margin:3px 0}
  .inv-a5 table{width:100%;border-collapse:collapse;font-size:12px;margin-top:12px}
  .inv-a5 th{background:#f5f5f5;padding:7px 10px;text-align:left;font-weight:700;border:1px solid #ddd}
  .inv-a5 td{padding:7px 10px;border:1px solid #ddd}
  .inv-a5 .total-row{font-weight:800;font-size:14px}
  @page{margin:0;size:A5}
}

/* ═══ DEV LOG ══════════════════════════════════════════ */
.dl-tab{padding:7px 16px;border-radius:99px;border:1px solid var(--border);font-size:13px;font-weight:500;color:var(--muted);background:var(--card);transition:all .15s}
.dl-tab:hover{border-color:var(--p);color:var(--p)}
.dl-tab.on{background:var(--p);color:#fff;border-color:var(--p)}
.dl-panel{display:none}.dl-panel.on{display:block}
.version-block{background:var(--card);border-radius:var(--r);border:1px solid var(--border);margin-bottom:12px;overflow:hidden}
.version-head{padding:12px 16px;background:#F8F9FA;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
.version-badge{background:var(--p);color:#fff;padding:2px 10px;border-radius:99px;font-size:11px;font-weight:700;font-family:'Courier New',monospace}
.version-date{font-size:12px;color:var(--muted)}
.version-items{padding:12px 16px}
.version-item{padding:4px 0;font-size:13px;border-bottom:1px solid #F5F6F7;display:flex;gap:8px;align-items:flex-start}
.version-item:last-child{border-bottom:none}
.vi-dot{font-size:10px;margin-top:4px;flex-shrink:0}
.bug-tbl{width:100%;border-collapse:collapse;font-size:12px}
.bug-tbl th{padding:8px 12px;background:#F8F9FA;font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:.4px;border-bottom:2px solid var(--border);text-align:left;white-space:nowrap}
.bug-tbl td{padding:8px 12px;border-bottom:1px solid #F1F3F4;vertical-align:top}
.bug-tbl tr:hover td{background:#F8FBFF}
.bug-tbl tr:last-child td{border-bottom:none}
.api-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);margin-bottom:12px}
.api-head{padding:12px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
.api-method{padding:2px 8px;border-radius:4px;font-size:10px;font-weight:700;background:#FF6B35;color:#fff;font-family:'Courier New',monospace}
.api-path{font-family:'Courier New',monospace;font-size:13px;color:var(--p)}
.api-body{padding:12px 16px}
.code-block{background:#1E2029;color:#E6EDF3;padding:14px 16px;border-radius:var(--r);font-family:'Courier New',monospace;font-size:12px;line-height:1.6;overflow-x:auto;white-space:pre;margin-top:8px}
.code-block .kw{color:#FF79C6}
.code-block .str{color:#F1FA8C}
.code-block .cmt{color:#6272A4}
.code-block .fn{color:#50FA7B}
.phase-card{border-left:4px solid var(--p);padding:12px 16px;background:var(--p-lt);border-radius:0 var(--r) var(--r) 0;margin-bottom:10px}
.phase-card.amber{border-left-color:var(--amber);background:var(--amber-lt)}
.phase-card.green{border-left-color:var(--green);background:var(--green-lt)}
.roadmap-week{background:var(--card);border:1px solid var(--border);border-radius:var(--r);margin-bottom:12px;overflow:hidden}
.rw-head{padding:10px 16px;background:#F8F9FA;border-bottom:1px solid var(--border);font-weight:700;font-size:14px;display:flex;gap:10px;align-items:center}
.rw-badge{background:var(--indigo);color:#fff;padding:1px 8px;border-radius:99px;font-size:11px}
.rw-body{padding:10px 16px}
.rw-task{padding:5px 0;font-size:13px;display:flex;gap:8px;border-bottom:1px solid #F5F6F7}
.rw-task:last-child{border-bottom:none}
.ai-prompt{background:#1E2029;color:#E6EDF3;padding:20px;border-radius:var(--r);font-family:'Courier New',monospace;font-size:12px;line-height:1.8;white-space:pre-wrap;overflow-x:auto}
.err-tag{display:inline-block;padding:1px 7px;border-radius:4px;font-size:10px;font-weight:700;margin-right:4px}
.priority-critical{background:var(--red-lt);color:var(--red)}
.priority-high{background:var(--amber-lt);color:var(--amber)}
.priority-medium{background:var(--p-lt);color:var(--p)}
.priority-low{background:#F1F3F4;color:var(--muted)}
@media(max-width:768px){
  #sb{position:fixed;transform:translateX(-100%);transition:transform .25s}
  #sb.open{transform:none;box-shadow:var(--sh)}
  .main{margin-left:0!important}
  .dash-grid{grid-template-columns:1fr}
  .fg{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- ══════════ AUTH ══════════ -->
<div id="auth" class="hidden">
  <div class="auth-box">
    <div class="auth-av" id="auth-av">YB</div>
    <h2 class="auth-title" id="auth-name">YB Dashboard</h2>
    <p class="auth-sub">Sign in to manage your store</p>
    <div style="position:relative;margin-bottom:10px">
      <span style="position:absolute;left:13px;top:50%;transform:translateY(-50%);opacity:.45;pointer-events:none">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      </span>
      <input class="auth-inp" type="password" id="pw" placeholder="Password" autocomplete="current-password" style="padding-left:38px;padding-right:42px;margin-bottom:0">
      <button onclick="togglePw()" tabindex="-1" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;opacity:.45;padding:4px" id="pw-eye">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" id="eye-icon"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
      </button>
    </div>
    <button class="auth-btn" id="login-btn" onclick="doLogin()">
      <span id="login-txt">Sign in</span>
      <span id="login-spin" style="display:none">...</span>
    </button>
    <div class="auth-err" id="auth-err"></div>
  </div>
</div>

<!-- ══════════ APP ══════════ -->
<div id="app" class="hidden">

  <!-- Sidebar -->
  <aside id="sb">
    <div class="sb-head">
      <div id="sb-logo">YB</div>
      <div class="sb-brand"><div id="sb-name">YIN BORAN</div><div id="sb-sub">Electronics</div></div>
      <button class="sb-tog" onclick="toggleSb()"><svg viewBox="0 0 24 24"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg></button>
    </div>
    <nav class="sb-nav">
      <span class="sb-sep">Main</span>
      <button class="nb-item on" data-p="dashboard" onclick="go('dashboard')">
        <span class="nb-icon"><svg viewBox="0 0 24 24"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg></span>
        <span class="nb-lbl">Dashboard</span>
      </button>
      <button class="nb-item" data-p="customers" onclick="go('customers')">
        <span class="nb-icon"><svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg></span>
        <span class="nb-lbl">Customers</span>
        <span class="nb-bdg" id="nb-c">0</span>
      </button>
      <button class="nb-item" data-p="products" onclick="go('products')">
        <span class="nb-icon"><svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg></span>
        <span class="nb-lbl">Products</span>
        <span class="nb-bdg" id="nb-p">0</span>
      </button>
      <button class="nb-item" data-p="reports" onclick="go('reports')">
        <span class="nb-icon"><svg viewBox="0 0 24 24"><path d="M5 9.2h3V19H5V9.2zM10.6 5h2.8v14h-2.8V5zm5.6 8H19v6h-2.8v-6z"/></svg></span>
        <span class="nb-lbl">Reports</span>
      </button>
      <span class="sb-sep">System</span>
      <button class="nb-item" data-p="settings" onclick="go('settings')">
        <span class="nb-icon"><svg viewBox="0 0 24 24"><path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.21.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/></svg></span>
        <span class="nb-lbl">Settings</span>
      </button>
      <button class="nb-item" data-p="devlog" onclick="go('devlog')">
        <span class="nb-icon"><svg viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg></span>
        <span class="nb-lbl">Dev Log</span>
      </button>
    </nav>
    <div class="sb-foot">
      <div class="sb-user"><div class="sb-av" id="sb-av">A</div><span class="sb-un" id="sb-un">Admin</span></div>
      <button class="nb-item" onclick="doLogout()" style="color:var(--red)">
        <span class="nb-icon"><svg viewBox="0 0 24 24"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg></span>
        <span class="nb-lbl">Sign out</span>
      </button>
    </div>
  </aside>

  <!-- Main -->
  <div class="main">
    <header class="topbar">
      <span class="tb-crumb" id="tb-crumb">Dashboard</span>
      <div class="tb-srch">
        <svg viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
        <input type="search" id="g-srch" placeholder="Search name, phone, order…" oninput="gSearch(this.value)">
      </div>
      <div class="tb-right">
        <span id="chip" class="chip test">TEST</span>
        <button class="tb-btn" onclick="refreshPage()">
          <svg viewBox="0 0 24 24"><path d="M17.65 6.35A7.958 7.958 0 0 0 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0 1 12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>Refresh
        </button>
        <button class="tb-btn" onclick="doLogout()">Logout</button>
      </div>
    </header>

    <main class="content" id="content">
      <!-- ── DASHBOARD ── -->
      <div id="pg-dashboard" class="page on">
        <div class="pg-head">
          <div><div class="pg-title">Dashboard</div><div class="pg-sub" id="dash-date"></div></div>
          <button class="btn btn-p" onclick="openAddCustomer()"><svg viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>Add Order</button>
        </div>
        <div class="metrics" id="dash-m">
          <div class="mc-skel skel" style="height:116px"></div>
          <div class="mc-skel skel" style="height:116px"></div>
          <div class="mc-skel skel" style="height:116px"></div>
          <div class="mc-skel skel" style="height:116px"></div>
          <div class="mc-skel skel" style="height:116px"></div>
          <div class="mc-skel skel" style="height:116px"></div>
        </div>
        <div class="dash-grid">
          <div class="sec">
            <div class="sec-h"><span class="sec-t">Undelivered Orders</span><span style="font-size:12px;color:var(--muted)">Needs action</span></div>
            <div id="dash-undelivered"><div class="skel-row"><div class="skel skel-cell" style="width:60%"></div></div><div class="skel-row"><div class="skel skel-cell" style="width:50%"></div></div></div>
          </div>
          <div class="sec">
            <div class="sec-h"><span class="sec-t">Orders by Status</span></div>
            <div class="sec-b" id="dash-chart"></div>
          </div>
        </div>
        <div class="sec" id="dash-alerts-sec" style="display:none">
          <div class="sec-h">
            <span class="sec-t" style="color:var(--amber)">⚠ Low Stock Alerts</span>
            <button class="btn btn-o" onclick="go('products')" style="font-size:12px;height:28px">Manage Stock →</button>
          </div>
          <div class="sec-b" id="dash-alerts-b"></div>
        </div>
      </div>

      <!-- ── CUSTOMERS ── -->
      <div id="pg-customers" class="page">
        <div class="pg-head">
          <div><div class="pg-title">Customers</div><div class="pg-sub" id="c-sub">Loading…</div></div>
          <div style="display:flex;gap:8px">
            <button class="btn btn-o" onclick="exportPDF('customers')"><svg viewBox="0 0 24 24"><path d="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"/></svg>Print / PDF</button>
            <button class="btn btn-p" onclick="openAddCustomer()"><svg viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>Add Customer</button>
          </div>
        </div>
        <div class="fbar">
          <div class="fs-wrap"><svg viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
            <input type="search" id="c-s" placeholder="Name, phone, ordered…" oninput="debounceCust()"></div>
          <select id="c-st" onchange="renderCust()"><option value="">All Status</option><option>Pending</option><option>Approved</option><option>Completed</option><option>Cancelled</option></select>
          <select id="c-pm" onchange="renderCust()"><option value="">All Payment</option><option value="paid">Paid</option><option value="unpaid">Unpaid</option></select>
          <input type="date" id="c-df" onchange="renderCust()" title="From">
          <input type="date" id="c-dt" onchange="renderCust()" title="To">
          <button class="btn btn-o" onclick="clearCF()" style="height:34px">Clear</button>
        </div>
        <div class="tbl-wrap">
          <div class="tbl-bar"><span class="tbl-count" id="c-cnt">—</span></div>
          <div class="tbl-body" id="c-tbl"><div id="c-skel"></div></div>
          <div id="cust-sentinel"><div class="load-more-spin" id="c-spin"></div></div>
        </div>
      </div>

      <!-- ── PRODUCTS ── -->
      <div id="pg-products" class="page">
        <div class="pg-head">
          <div><div class="pg-title">Products</div><div class="pg-sub" id="p-sub">Loading…</div></div>
          <button class="btn btn-p" onclick="openAddProduct()"><svg viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>Add Product</button>
        </div>
        <div class="fbar">
          <div class="fs-wrap"><svg viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
            <input type="search" id="p-s" placeholder="Code, name…" oninput="renderProd()"></div>
          <select id="p-ss" onchange="renderProd()"><option value="">All Stock</option><option value="in">In Stock</option><option value="low">Low Stock</option><option value="out">Out of Stock</option></select>
          <button class="btn btn-o" onclick="document.getElementById('p-s').value='';document.getElementById('p-ss').value='';renderProd()" style="height:34px">Clear</button>
        </div>
        <div class="tbl-wrap">
          <div class="tbl-bar"><span class="tbl-count" id="p-cnt">—</span></div>
          <div class="tbl-body" id="p-tbl"></div>
          <div id="prod-sentinel"><div class="load-more-spin" id="p-spin"></div></div>
        </div>
      </div>

      <!-- ── REPORTS ── -->
      <div id="pg-reports" class="page">
        <div class="pg-head">
          <div><div class="pg-title">Reports</div><div class="pg-sub">Filter and analyse</div></div>
          <button class="btn btn-p" onclick="window.print()"><svg viewBox="0 0 24 24"><path d="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"/></svg>Print</button>
        </div>
        <div class="fbar" style="margin-bottom:20px">
          <label style="font-size:13px;font-weight:500">From:</label><input type="date" id="r-f" onchange="loadReports()">
          <label style="font-size:13px;font-weight:500">To:</label><input type="date" id="r-t" onchange="loadReports()">
          <button class="btn btn-o" onclick="setRange('m')">This Month</button>
          <button class="btn btn-o" onclick="setRange('a')">All Time</button>
        </div>
        <div class="metrics" id="r-m"></div>
        <div class="dash-grid">
          <div class="sec"><div class="sec-h"><span class="sec-t">By Status</span></div><div class="sec-b" id="r-cs"></div></div>
          <div class="sec"><div class="sec-h"><span class="sec-t">Top Products</span></div><div class="sec-b" id="r-cp"></div></div>
        </div>
        <div class="sec" style="margin-top:20px"><div class="sec-h"><span class="sec-t">Order List</span></div><div id="r-tbl"></div></div>
      </div>

      <!-- ── SETTINGS ── -->
      <div id="pg-settings" class="page">
        <div class="pg-head">
          <div><div class="pg-title">Settings</div><div class="pg-sub">Read from Settings sheet row 2</div></div>
        </div>
        <div class="sec"><div class="sec-h"><span class="sec-t">Configuration</span><span style="font-size:12px;color:var(--muted)">Edit in Google Sheets → Settings tab</span></div>
          <div class="sec-b"><div id="settings-b"><div class="skel skel-cell" style="height:180px"></div></div></div>
        </div>
      </div>

      <!-- ── DEV LOG ── -->
      <div id="pg-devlog" class="page">
        <div class="pg-head">
          <div><div class="pg-title">Dev Log</div><div class="pg-sub">Project reference, bug registry, PayWay guide &amp; AI prompt</div></div>
          <div style="display:flex;gap:8px;flex-wrap:wrap">
            <button class="btn btn-o" onclick="saveDevLog()" id="btn-save-doc">

let prodIO;

function renderProd(){
  const rows=D.prod.raw; if(!rows||rows.length<2){ document.getElementById('p-tbl').innerHTML='<div class="empty-row">No products</div>'; return; }
  const hm=cm(rows[0]);
  const srch=(document.getElementById('p-s')?.value||'').toLowerCase();
  const ss_f=(document.getElementById('p-ss')?.value||'').toLowerCase();

  D.prod.filtered=rows.slice(1).filter(r=>{
    const code=s(r,hm,'Code').toLowerCase(), name=s(r,hm,'Item Name').toLowerCase(), cat=s(r,hm,'Category').toLowerCase();
    if(srch&&!code.includes(srch)&&!name.includes(srch)&&!cat.includes(srch)) return false;
    const st=s(r,hm,'Stock Status').toLowerCase();
    if(ss_f==='in'&&!st.includes('in stock')) return false;
    if(ss_f==='low'&&!st.includes('low')) return false;
    if(ss_f==='out'&&!st.includes('out')) return false;
    return true;
  });

  document.getElementById('p-cnt').textContent=D.prod.filtered.length+' products';
  document.getElementById('p-sub').textContent=D.prod.filtered.length+' products';

  D.prod.offset=0;
  if(!D.prod.filtered.length){ document.getElementById('p-tbl').innerHTML='<div class="empty-row">No products found</div>'; return; }
  document.getElementById('p-tbl').innerHTML=buildProdTable(D.prod.filtered.slice(0,D.prod.chunk), rows[0]);
  D.prod.offset=Math.min(D.prod.chunk, D.prod.filtered.length);
  setupProdIO();
}

function buildProdTable(rows, headers){
  const hm=cm(headers);
  const cols=['Code','Item Name','Category','Quantity','Retail Price','Stock Status'];
  const th=cols.map((c,i)=>`<th class="${D.prod.sortC===i?(D.prod.sortD===1?'sorted-a':'sorted-d'):''}" onclick="sortProd(${i})">${c}<i class="si"></i></th>`).join('');
  const tb=rows.map(r=>{
    const code=s(r,hm,'Code');
    const qty=parseInt(s(r,hm,'Quantity').replace(/[^0-9]/g,''))||0;
    const maxQ=20; const pct=Math.min(100,Math.round(qty/maxQ*100));
    const st=s(r,hm,'Stock Status').toLowerCase();
    const bc=st.includes('out')?'var(--red)':st.includes('low')?'var(--amber)':'var(--green)';
    const cells=cols.map(c=>{
      const v=s(r,hm,c);
      if(c==='Stock Status') return `<td>${sstBdg(v)}</td>`;
      if(c==='Quantity') return `<td class="num">${qty}<div class="stk-bar"><div class="stk-fill" style="width:${pct}%;background:${bc}"></div></div></td>`;
      if(c==='Retail Price') return `<td class="num">${v||'—'}</td>`;
      return `<td title="${e(v)}">${t(v,24)||'—'}</td>`;
    }).join('');
    return `<tr>${cells}<td><div class="ra">
      <button class="rb e" onclick="editProd(${JSON.stringify(code)})" title="Edit"><svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg></button>
      <button class="rb d" onclick="delProdConfirm(${JSON.stringify(code)})" title="Delete"><svg viewBox="0 0 24 24"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg></button>
    </div></td></tr>`;
  }).join('');
  return `<table class="tbl"><thead><tr>${th}<th></th></tr></thead><tbody>${tb}</tbody></table>`;
}

function setupProdIO(){
  if(prodIO) prodIO.disconnect();
  const sentinel=document.getElementById('prod-sentinel');
  if(!sentinel) return;
  prodIO=new IntersectionObserver(entries=>{
    if(!entries[0].isIntersecting) return;
    if(D.prod.offset>=D.prod.filtered.length) return;
    const spin=document.getElementById('p-spin'); if(spin) spin.style.display='inline-block';
    setTimeout(()=>{
      const more=D.prod.filtered.slice(D.prod.offset, D.prod.offset+D.prod.chunk);
      const tbody=document.querySelector('#p-tbl .tbl tbody');
      if(tbody && more.length){
        const hm=cm(D.prod.raw[0]); const cols=['Code','Item Name','Category','Quantity','Retail Price','Stock Status'];
        more.forEach(r=>{
          const tr=document.createElement('tr');
          const code=s(r,hm,'Code');
          const cells=cols.map(c=>{ const v=s(r,hm,c); if(c==='Stock Status') return `<td>${sstBdg(v)}</td>`; return `<td>${t(v,24)||'—'}</td>`; }).join('');
          tr.innerHTML=`${cells}<td><div class="ra"><button class="rb e" onclick="editProd(${JSON.stringify(code)})"><svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg></button><button class="rb d" onclick="delProdConfirm(${JSON.stringify(code)})"><svg viewBox="0 0 24 24"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg></button></div></td>`;
          tbody.appendChild(tr);
        });
      }
      D.prod.offset+=D.prod.chunk;
      if(spin) spin.style.display='none';
    }, 200);
  });
  prodIO.observe(sentinel);
}

function sortProd(col){ if(D.prod.sortC===col) D.prod.sortD*=-1; else{D.prod.sortC=col;D.prod.sortD=1;} renderProd(); }


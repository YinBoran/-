<script>
// ═══════════════════════════════════════════════════════════
// STORAGE HELPER — must be defined BEFORE D uses it
// ═══════════════════════════════════════════════════════════
function ss(k, v){ if(v===undefined) return sessionStorage.getItem(k); sessionStorage.setItem(k,v); }

// ═══════════════════════════════════════════════════════════
// STATE — persisted keys use sessionStorage
// ═══════════════════════════════════════════════════════════
const D = {
  page: ss('page') || 'dashboard',
  sbCol: ss('sbc') === '1',
  cfg: { storeName:'YIN BORAN', initials:'YB', logoUrl:'', color:'#1A73E8', connectType:'TEST' },
  cust: { raw:[], filtered:[], offset:0, chunk:30, sortC:0, sortD:1 },
  prod: { raw:[], filtered:[], offset:0, chunk:30, sortC:0, sortD:1 },
  modal: { type:'', id:'' },
  cats: [],
  debTimer: null
};

// ═══════════════════════════════════════════════════════════
// GOOGLE SCRIPT BRIDGE
// ═══════════════════════════════════════════════════════════
function GS(fn, ...args) {
  return new Promise((ok, err) => {
    if(typeof google === 'undefined'){ err(new Error('Not connected')); return; }
    google.script.run.withSuccessHandler(ok).withFailureHandler(err)[fn](...args);
  });
}

// ═══════════════════════════════════════════════════════════
// AUTH
// ═══════════════════════════════════════════════════════════
function chkAuth(){ ss('ybauth')==='1' ? showApp() : showAuth(); }
function showAuth(){
  document.getElementById('auth').classList.remove('hidden');
  document.getElementById('app').classList.add('hidden');
  setTimeout(()=>{ const p=document.getElementById('pw'); if(p) p.focus(); },200);
}
function showApp(){ document.getElementById('auth').classList.add('hidden'); const a=document.getElementById('app'); a.classList.remove('hidden'); setTimeout(()=>a.classList.add('ready'),10); initApp(); }
document.getElementById('pw').addEventListener('keydown', e=>{ if(e.key==='Enter') doLogin(); });

let _pwVisible=false;
function togglePw(){
  _pwVisible=!_pwVisible;
  const inp=document.getElementById('pw');
  inp.type=_pwVisible?'text':'password';
  document.getElementById('eye-icon').style.opacity=_pwVisible?'1':'.45';
}

async function doLogin(){
  const pw  = document.getElementById('pw').value.trim();
  const err = document.getElementById('auth-err');
  const btn = document.getElementById('login-btn');
  const txt = document.getElementById('login-txt');
  const spn = document.getElementById('login-spin');
  err.textContent='';
  if(!pw){ err.textContent='Enter password'; return; }
  btn.disabled=true; txt.style.display='none'; spn.style.display='inline';
  try{
    const r = await GS('verifyPassword', pw);
    if(r===true){ ss('ybauth','1'); showApp(); }
    else{ err.textContent='Incorrect password'; document.getElementById('pw').value=''; document.getElementById('pw').focus(); }
  }catch(e){ err.textContent='Server error. Try again.'; console.error(e); }
  finally{ btn.disabled=false; txt.style.display='inline'; spn.style.display='none'; }
}
function doLogout(){ sessionStorage.clear(); location.reload(); }

// ═══════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════
async function initApp(){
  if(D.sbCol) toggleSb(true);
  loadCfg().then(()=>{ go(D.page, true); loadAll(); });
}

async function loadAll(){
  const [c, p] = await Promise.all([
    GS('getCustomersData').catch(()=>[]),
    GS('getProductsData').catch(()=>[])
  ]);
  if(c && c.length>1){ D.cust.raw=c; document.getElementById('nb-c').textContent=c.length-1; }
  if(p && p.length>1){ D.prod.raw=p; document.getElementById('nb-p').textContent=p.length-1; D.cats=extractCats(); }
  buildDash(); renderCust(); renderProd();
}

async function loadCfg(){
  try{ const c=await GS('getAppConfig'); if(c) applyCfg(c); }catch(_){ applyCfg(D.cfg); }
}
function applyCfg(c){
  D.cfg={...D.cfg,...c};
  if(c.primaryColor && /^#[0-9a-f]{6}$/i.test(c.primaryColor)){
    document.documentElement.style.setProperty('--p', c.primaryColor);
    document.documentElement.style.setProperty('--p-lt', c.primaryColor+'22');
  }
  const n = c.storeName||'YIN BORAN';
  document.getElementById('sb-name').textContent = n;
  document.getElementById('sb-sub').textContent  = c.storeSub||'Electronics';
  document.title = n+' Manages';
  const ini = n.split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase()||'YB';
  D.cfg.initials = ini;
  document.getElementById('sb-av').textContent   = ini[0]||'A';
  document.getElementById('auth-av').textContent = ini;
  document.getElementById('auth-name').textContent = n;
  ['sb-logo','auth-av'].forEach(id=>setLogo(id, c.logoUrl, ini));
  const chip = document.getElementById('chip');
  const ct = (c.connectType||'TEST').toUpperCase();
  chip.textContent = ct; chip.className = 'chip '+(ct==='PROD'?'prod':'test');
  document.getElementById('dash-date').textContent =
    'Today: '+new Date().toLocaleDateString('km-KH',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
}
function setLogo(id, url, ini){
  const el=document.getElementById(id); if(!el) return;
  if(url&&!url.includes('INSERT')&&!url.startsWith('https://your'))
    el.innerHTML=`<img src="${e(url)}" alt="logo" onerror="this.parentNode.textContent='${e(ini)}'">`;
  else el.textContent=ini;
}

// ═══════════════════════════════════════════════════════════
// NAVIGATION — state saved in sessionStorage
// ═══════════════════════════════════════════════════════════
function go(page, skipSave){
  D.page = page;
  if(!skipSave) ss('page', page);
  document.querySelectorAll('.nb-item[data-p]').forEach(el=>el.classList.toggle('on', el.dataset.p===page));
  document.querySelectorAll('.page').forEach(el=>el.classList.toggle('on', el.id==='pg-'+page));
  const names={dashboard:'Dashboard',customers:'Customers',products:'Products',reports:'Reports',settings:'Settings'};
  document.getElementById('tb-crumb').textContent = names[page]||page;
  if(page==='reports')  loadReports();
  if(page==='settings') loadSettings();
}
function toggleSb(restore){
  D.sbCol = restore===true ? true : !D.sbCol;
  document.getElementById('sb').classList.toggle('col', D.sbCol);
  ss('sbc', D.sbCol?'1':'0');
}
function refreshPage(){
  if(D.page==='customers'||D.page==='dashboard') loadAll();
  else if(D.page==='reports') loadReports();
  else if(D.page==='settings') loadSettings();
}

// ═══════════════════════════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════════════════════════
function buildDash(){
  const rows=D.cust.raw; if(!rows||rows.length<2) return;
  const hm=cm(rows[0]); const data=rows.slice(1);
  const today=new Date().toLocaleDateString('en-GB');

  let total=data.length, done=0, pending=0, approv=0, cancel=0, rev=0, cod=0, todayNew=0;
  const sCnt={};

  data.forEach(r=>{
    const st=s(r,hm,'Status').toLowerCase();
    const pm=s(r,hm,'Payment').toLowerCase();
    const tp=parseFloat(s(r,hm,'Total Paid').replace(/[^0-9.]/g,''))||0;
    const od=s(r,hm,'Order Date');
    if(st.includes('complet')){ done++; rev+=tp; }
    if(st.includes('pend')) pending++;
    if(st.includes('approv')) approv++;
    if(st.includes('cancel')) cancel++;
    if(pm.includes('cod')||pm==='cod') cod++;
    if(od&&od.includes(today.split('/').reverse().join('/'))) todayNew++;
    const k=st||'pending'; sCnt[k]=(sCnt[k]||0)+1;
  });

  // Metrics cards
  document.getElementById('dash-m').innerHTML = [
    {cl:'blue', ico:'M20 4H4c-1.11 0-2 .89-2 2v12c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z', v:total, l:'Total Orders'},
    {cl:'green', ico:'M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z', v:done, l:'Completed'},
    {cl:'amber', ico:'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z', v:pending+approv, l:'Pending / Approved'},
    {cl:'teal', ico:'M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z', v:cod, l:'COD Pending'},
    {cl:'indigo', ico:'M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z', v:'$'+rev.toFixed(0), l:'Revenue'},
    {cl:'blue', ico:'M19 3H5c-1.11 0-2 .89-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z', v:todayNew, l:'New Today'},
  ].map(m=>`<div class="mc ${m.cl}"><div class="mc-ico"><svg viewBox="0 0 24 24"><path d="${m.ico}"/></svg></div><div class="mc-val">${m.v}</div><div class="mc-lbl">${m.l}</div></div>`).join('');

  // Undelivered orders (approved or pending, no delivery date)
  const undel = data.filter(r=>{
    const st=s(r,hm,'Status').toLowerCase();
    const dd=s(r,hm,'Delivery Date');
    return (st.includes('approv')||st.includes('pend')) && !dd;
  }).slice(0,8);
  document.getElementById('dash-undelivered').innerHTML = undel.length
    ? `<table class="tbl"><thead><tr><th>Name</th><th>Phone</th><th>Ordered</th><th>Pricing</th><th>Payment</th><th>Status</th></tr></thead><tbody>${
        undel.map(r=>`<tr><td>${t(s(r,hm,'Name'),16)}</td><td>${s(r,hm,'Phone Number')||'—'}</td><td title="${e(s(r,hm,'Ordered'))}">${t(s(r,hm,'Ordered'),20)}</td><td class="num">${s(r,hm,'Pricing')||'—'}</td><td>${pBdg(s(r,hm,'Payment'))}</td><td>${sBdg(s(r,hm,'Status'))}</td></tr>`).join('')
      }</tbody></table>`
    : '<div style="padding:20px;text-align:center;color:var(--muted);font-size:13px">No pending orders 🎉</div>';

  // Chart
  const cd=[
    {l:'Completed',v:done,c:'var(--green)'},
    {l:'Approved',v:approv,c:'var(--p)'},
    {l:'Pending',v:pending,c:'var(--amber)'},
    {l:'Cancelled',v:cancel,c:'var(--red)'}
  ];
  const mx=Math.max(...cd.map(d=>d.v),1);
  document.getElementById('dash-chart').innerHTML=cd.map(d=>`
    <div class="ch-row"><div class="ch-lbl">${d.l}</div>
    <div class="ch-track"><div class="ch-fill" style="width:${Math.round(d.v/mx*100)}%;background:${d.c}"><span>${d.v}</span></div></div></div>`).join('');

  // Low stock alerts
  const pr=D.prod.raw; if(pr.length>1){
    const ph=cm(pr[0]);
    const low=pr.slice(1).filter(r=>{const ss=s(r,ph,'Stock Status').toLowerCase();return ss.includes('low')||ss.includes('out');});
    const sec=document.getElementById('dash-alerts-sec');
    if(low.length){
      sec.style.display='block';
      document.getElementById('dash-alerts-b').innerHTML=low.map(r=>`
        <div class="alert-row">
          <span style="font-weight:500">${e(s(r,ph,'Item Name')||s(r,ph,'Code'))}</span>
          <div style="display:flex;align-items:center;gap:10px">
            <span style="font-size:12px;color:var(--muted)">Qty: ${s(r,ph,'Quantity')||0}</span>
            ${sstBdg(s(r,ph,'Stock Status'))}
          </div>
        </div>`).join('');
    } else sec.style.display='none';
  }
}

// ═══════════════════════════════════════════════════════════
// CUSTOMERS — infinite scroll
// ═══════════════════════════════════════════════════════════
let custIO; // IntersectionObserver

function debounceCust(){ clearTimeout(D.debTimer); D.debTimer=setTimeout(renderCust, 280); }
function gSearch(v){ if(!v) return; if(D.page!=='customers') go('customers'); document.getElementById('c-s').value=v; renderCust(); }

function renderCust(){
  const rows=D.cust.raw; if(!rows||rows.length<2){ document.getElementById('c-tbl').innerHTML='<div class="empty-row">No data</div>'; return; }
  const hm=cm(rows[0]);
  const data=rows.slice(1).filter(r=>{
    // Filter empty rows (safety net for any that slip through server-side filter)
    return s(r,hm,'Profile ID')||s(r,hm,'Phone Number');
  });

  const srch=(document.getElementById('c-s')?.value||'').toLowerCase();
  const st=(document.getElementById('c-st')?.value||'').toLowerCase();
  const pm=(document.getElementById('c-pm')?.value||'').toLowerCase();
  const df=document.getElementById('c-df')?.value;
  const dt=document.getElementById('c-dt')?.value;

  D.cust.filtered = data.filter(r=>{
    if(srch&&![s(r,hm,'Name'),s(r,hm,'Phone Number'),s(r,hm,'Ordered'),s(r,hm,'Location')].some(v=>v.toLowerCase().includes(srch))) return false;
    if(st && !s(r,hm,'Status').toLowerCase().includes(st)) return false;
    if(pm==='paid' && !s(r,hm,'Payment').toLowerCase().includes('paid')) return false;
    if(pm==='unpaid' && s(r,hm,'Payment').toLowerCase().includes('paid')) return false;
    const od=s(r,hm,'Order Date'); if(df&&od&&pd(od)<new Date(df)) return false;
    if(dt&&od&&pd(od)>new Date(dt+'T23:59:59')) return false;
    return true;
  });

  const sC=D.cust.sortC, sD=D.cust.sortD;
  D.cust.filtered.sort((a,b)=>{
    const cols=['Name','Phone Number','Ordered','Pricing','Retail Price','Payment','Status','Order Date'];
    const av=s(a,hm,cols[sC]||'');
    const bv=s(b,hm,cols[sC]||'');
    return av.localeCompare(bv,undefined,{numeric:true})*sD;
  });

  document.getElementById('c-cnt').textContent=D.cust.filtered.length+' records';
  document.getElementById('c-sub').textContent=D.cust.filtered.length+' records';

  D.cust.offset=0;
  if(D.cust.filtered.length===0){
    document.getElementById('c-tbl').innerHTML='<div class="empty-row">No records found</div>';
    return;
  }
  document.getElementById('c-tbl').innerHTML=buildCustTable(D.cust.filtered.slice(0, D.cust.chunk), rows[0]);
  D.cust.offset=Math.min(D.cust.chunk, D.cust.filtered.length);
  setupCustIO();
}

function buildCustTable(rows, headers){
  const hm=cm(headers);
  const cols=['Name','Phone Number','Ordered','Pricing','Retail Price','Discount','Payment','Status','Order Date'];
  const th=cols.map((c,i)=>`<th class="${D.cust.sortC===i?(D.cust.sortD===1?'sorted-a':'sorted-d'):''}" onclick="sortCust(${i})">${c}<i class="si"></i></th>`).join('');
  const tb=rows.map(r=>{
    const pid=s(r,hm,'Profile ID');
    const cells=cols.map(c=>{
      const v=s(r,hm,c);
      if(c==='Payment') return `<td>${pBdg(v)}</td>`;
      if(c==='Status')  return `<td>${sBdg(v)}</td>`;
      if(c==='Pricing'||c==='Retail Price'||c==='Discount') return `<td class="num">${v||'—'}</td>`;
      if(c==='Name') return `<td><div style="display:flex;align-items:center;gap:6px">
        <button class="rb p" onclick="printLabel(${JSON.stringify(pid)})" title="Print label"><svg viewBox="0 0 24 24"><path d="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"/></svg></button>
        <span title="${e(v)}">${t(v,18)||'—'}</span></div></td>`;
      if(c==='Phone Number') return `<td><a href="#" onclick="printInvoiceA5(${JSON.stringify(pid)});return false;" style="color:var(--p);font-weight:500" title="View A5 Invoice">${v||'—'}</a></td>`;
      return `<td title="${e(v)}">${t(v,22)||'—'}</td>`;
    }).join('');
    return `<tr>${cells}<td><div class="ra">
      <button class="rb e" onclick="editCust(${JSON.stringify(pid)})" title="Edit"><svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg></button>
      <button class="rb d" onclick="delCustConfirm(${JSON.stringify(pid)})" title="Delete"><svg viewBox="0 0 24 24"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg></button>
    </div></td></tr>`;
  }).join('');
  return `<table class="tbl"><thead><tr>${th}<th></th></tr></thead><tbody>${tb}</tbody></table>`;
}

function setupCustIO(){
  if(custIO) custIO.disconnect();
  const sentinel=document.getElementById('cust-sentinel');
  if(!sentinel) return;
  custIO=new IntersectionObserver(entries=>{
    if(!entries[0].isIntersecting) return;
    if(D.cust.offset>=D.cust.filtered.length) return;
    const spin=document.getElementById('c-spin');
    if(spin) spin.style.display='inline-block';
    setTimeout(()=>{
      const more=D.cust.filtered.slice(D.cust.offset, D.cust.offset+D.cust.chunk);
      if(!more.length) return;

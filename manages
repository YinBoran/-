function toast(msg,type='info',dur=3000){ const w=document.getElementById('toasts'); const el=document.createElement('div'); el.className=`toast ${type}`; el.innerHTML=`<svg viewBox="0 0 24 24"><path d="${ICONS[type]||ICONS.info}"/></svg>${e(msg)}`; w.appendChild(el); setTimeout(()=>{ el.classList.add('out'); setTimeout(()=>el.remove(),250); },dur); }


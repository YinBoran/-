async function loadReports(){
  const rows=D.cust.raw; if(!rows||rows.length<2){ await loadAll(); return; }
  const hm=cm(rows[0]); const data=rows.slice(1).filter(r=>s(r,hm,'Profile ID')||s(r,hm,'Phone Number'));
  const rf=document.getElementById('r-f')?.value, rt=document.getElementById('r-t')?.value;
  const filt=data.filter(r=>{ const od=s(r,hm,'Order Date'); if(rf&&od&&pd(od)<new Date(rf)) return false; if(rt&&od&&pd(od)>new Date(rt+'T23:59:59')) return false; return true; });
  let tot=filt.length, done=0, rev=0, cancel=0, cod=0; const sCnt={}, pCnt={};
  filt.forEach(r=>{ const st=s(r,hm,'Status').toLowerCase(), pm=s(r,hm,'Payment').toLowerCase(), tp=parseFloat(s(r,hm,'Total Paid').replace(/[^0-9.]/g,''))||0, code=s(r,hm,'Code')||'Other'; if(st.includes('complet')){done++;rev+=tp;} if(st.includes('cancel'))cancel++; if(pm.includes('cod'))cod++; sCnt[st]=(sCnt[st]||0)+1; pCnt[code]=(pCnt[code]||0)+1; });
  document.getElementById('r-m').innerHTML=[{cl:'blue',v:tot,l:'Total'},{cl:'green',v:done,l:'Completed'},{cl:'indigo',v:'$'+rev.toFixed(2),l:'Revenue'},{cl:'red',v:cancel,l:'Cancelled'}].map(m=>`<div class="mc ${m.cl}"><div class="mc-val">${m.v}</div><div class="mc-lbl">${m.l}</div></div>`).join('');

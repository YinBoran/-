    const result = await GS('writeDevLogToDoc');
    if(result && result.success){ toast('✅ Saved to Google Doc!','success'); }
    else{ toast('⚠️ Save failed: '+(result&&result.message||'Check Apps Script logs'),'error'); }
  }catch(err){ toast('Error: '+err.message,'error'); }
  finally{ if(btn){ btn.disabled=false; btn.innerHTML='<svg viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm4 18H6V4h7v5h5v11z"/></svg>Save to Google Doc'; } }
}

